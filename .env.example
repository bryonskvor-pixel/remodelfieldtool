# ScopeWalk server configuration
# Copy to .env — never commit .env. Real credentials belong ONLY in .env.

# Local libSQL database file (always used; this IS the offline store).
LOCAL_DB_PATH=file:./data/scopewalk.db

# Turso remote sync. When set, the local file becomes an embedded replica
# that syncs to Turso.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Auth
SESSION_TTL_DAYS=90
MAGIC_LINK_TTL_MINUTES=15
# Pilot: magic links are printed to the server console instead of emailed.
# Set to an email provider id when one is wired (e.g. "resend").
EMAIL_PROVIDER=console

# App origin used when constructing magic links
APP_ORIGIN=http://localhost:5173

# Seeding the pilot contractor (used by `npm run seed`)
SEED_CONTRACTOR_EMAIL=
SEED_CONTRACTOR_BUSINESS_NAME=
SEED_CONTRACTOR_OWNER_NAME=

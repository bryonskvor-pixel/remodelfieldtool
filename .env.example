# ScopeWalk server configuration
# Copy to .env — never commit .env. Real credentials belong ONLY in .env.

# Local libSQL database file (always used; this IS the offline store).
LOCAL_DB_PATH=file:./data/scopewalk.db

# Turso remote sync. When set, the local file becomes an embedded replica
# that syncs to Turso. Paste the URL bare — no quotes, no trailing spaces or
# newline: the native driver panics on a malformed URI rather than reporting it.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Hosted/stateless deployments (Render): skip the embedded replica and talk to
# Turso directly over HTTP. Leave unset for local dev.
# DB_REMOTE_ONLY=true

# Auth
SESSION_TTL_DAYS=90
MAGIC_LINK_TTL_MINUTES=15
# "console" prints magic links to the server log (local dev). "resend" emails
# them via the Resend API (production) — requires RESEND_API_KEY below.
EMAIL_PROVIDER=console
# From-address for sign-in emails (must be on a Resend-verified domain).
AUTH_EMAIL_FROM=ScopeWalk <login@cleanconstructionllc.com>
# Reused from the marketing site's verified Resend domain.
RESEND_API_KEY=

# App origin used when constructing magic links. In production set this to the
# public URL (e.g. https://scopewalk.cleanconstructionllc.com).
APP_ORIGIN=http://localhost:5173

# Production single-origin serving: the server serves app/dist alongside the
# API. Set SERVE_STATIC=false to run the API standalone; PWA_DIST overrides the
# built-app location (defaults to ../app/dist relative to the server source).
# SERVE_STATIC=true
# PWA_DIST=

# Seeding the pilot contractor (used by `npm run seed`)
SEED_CONTRACTOR_EMAIL=
SEED_CONTRACTOR_BUSINESS_NAME=
SEED_CONTRACTOR_OWNER_NAME=

# Groq Whisper transcription (Phase 1)
GROQ_API_KEY=

# Cloudflare R2 — photos + audio (§3)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=scopewalk-media

# Claude API — proposal scope-narrative drafting (Phase 2 §9)
ANTHROPIC_API_KEY=
